def write_default_permissions(workspace)
  settings_dir = File.join(workspace, ".claude")
  FileUtils.mkdir_p(settings_dir)
  settings_file = File.join(settings_dir, "settings.json")

  settings = File.exist?(settings_file) ? JSON.parse(File.read(settings_file)) : {}
  settings["permissions"] ||= {}
  settings["permissions"]["allow"] = DEFAULT_PERMISSIONS.dup

  File.write(settings_file, JSON.pretty_generate(settings) + "\n")
end

# --- Slack ---

def slack_context_lines(url)
  match = url.match(%r{/archives/([^/]+)/p(\d+)})
  return nil unless match

  channel_id = match[1]
  raw_ts = match[2]
  message_ts = "#{raw_ts[0..-7]}.#{raw_ts[-6..]}"

  <<~MD.strip
    ## Slack context

    Read this Slack thread using slack_read_thread (channel_id: #{channel_id}, message_ts: #{message_ts}).
    Source: #{url}

    ## How to work with me

    You are a strategic thinking partner. Your job is to make me sharper, not to do my thinking for me.

    After reading the thread:
    1. Give me a concise summary of what's being discussed and what's at stake
    2. Tell me what you think my options are — including ones I might not like
    3. Ask me what I think before offering your opinion

    As we talk:
    - Push back when my reasoning is sloppy or self-serving
    - Ask "what would have to be true for you to change your mind?"
    - Name the tradeoffs I'm glossing over
    - If I'm avoiding something, say so
    - Don't let me settle for a comfortable answer when a better one exists

    Keep responses short. I'm here to think, not to read.
  MD
end

def write_slack_context(workspace, url)
  lines = slack_context_lines(url)
  return unless lines

  File.write(File.join(workspace, "CLAUDE.md"), <<~MD)
    #{lines}
  MD
end

main
